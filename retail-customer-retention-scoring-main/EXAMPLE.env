# MongoDB -- the gateway reads behavioral data and writes churn_risk_scores back
MONGODB_URI=

# MongoDB database name (default: leafy_popup_store)
DATABASE_NAME=leafy_popup_store

# Microsoft Fabric ML model endpoint (the churn model is trained AND served in
# Fabric). Find the workspace and model IDs under the Fabric model's endpoint
# details.
FABRIC_API_BASE=https://api.fabric.microsoft.com
FABRIC_WORKSPACE_ID=
FABRIC_MODEL_ID=

# Optional: managed identity client id for the Fabric token in Azure.
# Leave empty locally to use your `az login` (DefaultAzureCredential).
# AZURE_CLIENT_ID=

# Port. Use 8081 locally to avoid clashing with the backend (which uses 8080).
# This must match the backend's SCORING_SERVICE_URL. Azure Container Apps
# overrides this to 8080 at deploy time.
PORT=8081
