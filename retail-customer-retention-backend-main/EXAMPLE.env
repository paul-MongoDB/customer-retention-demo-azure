# MongoDB -- direct connection for change stream watcher
MONGODB_URI=

# MongoDB database name (default: leafy_popup_store)
DATABASE_NAME=leafy_popup_store

# MongoDB MCP Server (Azure Container Apps)
MCP_SERVER_URL=
# Foundry project connection name for the MCP server (default: mongodb-mcp-server)
# MCP_CONNECTION_NAME=mongodb-mcp-server

# Voyage AI (embeddings handled by MCP server, key starts with pa-)
VOYAGE_API_KEY=

# Microsoft Foundry (agents are created here and visible in the portal)
AZURE_AI_PROJECT_ENDPOINT=
AZURE_AI_MODEL_DEPLOYMENT_NAME=<your-model-deployment-name>

# Real-time churn scoring service. The Fabric-enriched exit-risk agent calls this,
# and setup_agents.py bakes it into the OpenAPI tool. Use localhost for dev; in
# Azure use the deployed scoring Container App FQDN (must be reachable by Foundry).
SCORING_SERVICE_URL=http://localhost:8081

# Startup default for the Fabric enrichment toggle (true/false). Flip at runtime
# with POST /enrichment/on or /enrichment/off.
FABRIC_ENRICHMENT_ENABLED=false

# Azure credentials (DefaultAzureCredential -- run `az login` before starting)
# Or set AZURE_CLIENT_ID / AZURE_TENANT_ID / AZURE_CLIENT_SECRET for service principal auth
