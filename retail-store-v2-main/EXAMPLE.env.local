# ---- Required for the customer retention demo ----

# MongoDB Atlas connection string
MONGODB_URI=
# Database that holds the demo data (must match what you seeded and what the
# backend/scoring services use)
DATABASE_NAME=leafy_popup_store
NODE_ENV=development

# VoyageAI API key, used by product semantic search (get one at https://www.voyageai.com)
VOYAGE_API_KEY=
# Atlas Vector Search index name on products.vai_text_embedding
# (optional, defaults to vs_index_vai_text_embeddings if unset)
VECTOR_INDEX_NAME=vs_index_vai_text_embeddings

# Base URL of the retention backend (the Fabric enrichment toggle calls this).
# Local: run the backend on port 8000 (PORT=8000) so it doesn't clash with the
# storefront's 8080, and point this at it. Azure: the backend Container App FQDN.
RETENTION_BACKEND_URL=http://localhost:8000

# Only needed if the backend sets ADMIN_API_KEY: same value here, so the
# server-side enrichment proxy can call the protected endpoints. Never exposed
# to the browser.
ADMIN_API_KEY=

# ---- Optional: only needed for the other storefront features ----

# Dataworkz RAG chatbot (see resources/chatbot/README.md)
DATAWORKZ_SERVICE=
DATAWORKZ_AGENT_ID=
DATAWORKZ_LLM_ID=
DATAWORKZ_TOKEN=
NEXT_PUBLIC_CHATBOT_PASSWORD=

# Digital receipts invoice function (see resources/digitalReceipts/README.md)
GCP_INVOICE_URL=
